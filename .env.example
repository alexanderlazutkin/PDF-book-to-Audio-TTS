# === Бэкенд LLM ===
# Какую модель использовать для очистки текста:
#   lmstudio — локальная LMStudio (OpenAI-совместимый API, по умолчанию)
#   ollama   — локальная Ollama
#   openai   — облачный OpenAI API
LLM_BACKEND=lmstudio

# === LMStudio (локальная модель) ===
# OpenAI-совместимый эндпоинт LMStudio.
# Запустите сервер в LMStudio: вкладка "Developer" → "Start Server".
LMSTUDIO_BASE_URL=http://localhost:1234/v1
# Имя загруженной в LMStudio модели (как в GET /v1/models).
LMSTUDIO_MODEL=qwen3.6-35b-a3b-mtp
# LMStudio не требует ключа, но OpenAI SDK требует непустое значение.
LMSTUDIO_API_KEY=lm-studio

# === Ollama (используется только если LLM_BACKEND=ollama) ===
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1:8b
OLLAMA_API_KEY=ollama

# === OpenAI (используется только если LLM_BACKEND=openai) ===
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5-nano

# === Общие настройки LLM ===
LLM_TEMPERATURE=0
LLM_TIMEOUT=600
MAX_CONTENT_TOKENS=9500

# === Пути ===
BOOK_PATH=./data/book.txt
OUT_DIR=./out

# === Yandex SpeechKit ===
# Укажи только один из вариантов (API key ИЛИ IAM token + Folder ID)
# SPEECHKIT_API_KEY=aje3p3e703ovfo05tucj

# Или IAM-токен + Folder ID
IAM_TOKEN=tokennnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnn
FOLDER_ID=folderrrrrrrrrrrrrrrrrrrrrrrrrrr